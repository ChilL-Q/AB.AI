# ── App ──────────────────────────────────────────────────────────────────────
APP_ENV=development
SECRET_KEY=change-me-in-production
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8081

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://abai:abai@localhost:5432/abai
DATABASE_SYNC_URL=postgresql://abai:abai@localhost:5432/abai

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── WhatsApp ──────────────────────────────────────────────────────────────────
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=

# ── Telegram ──────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=

# ── Claude (Anthropic) ────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── Email (Resend) ────────────────────────────────────────────────────────────
RESEND_API_KEY=
EMAIL_FROM=noreply@ab-ai.app

# ── Storage (Cloudflare R2 / S3) ──────────────────────────────────────────────
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=ab-ai

# ── Billing ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
KASPI_MERCHANT_ID=
KASPI_API_KEY=

# ── Monitoring ────────────────────────────────────────────────────────────────
SENTRY_DSN=
POSTHOG_API_KEY=
